# Template only — copy to ".env" in this folder and fill in values.
# The app loads ONLY ".env" (never this file). Commit .env.example; do not commit .env.

GROQ_API_KEY=
GITHUB_TOKEN=

# Endee VECTOR DATABASE only — NOT FastAPI. Must be a different port than uvicorn (8000).
# If ENDEE_URL uses the same host:port as API_BASE_URL, /api/v1/index/list hits FastAPI → 404.
ENDEE_URL=http://127.0.0.1:8001

# FastAPI + Inngest (uvicorn main:app --port 8000)
API_BASE_URL=http://127.0.0.1:8000

INNGEST_EVENT_KEY=local
# Leave empty for local Inngest dev server (do not use "local" — it is not valid hex).
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
# Optional: SDK HTTP timeout ms (long clone/embed steps)
# INNGEST_REQUEST_TIMEOUT_MS=600000
