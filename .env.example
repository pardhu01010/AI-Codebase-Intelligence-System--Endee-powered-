# Template only — copy to ".env" in this folder and fill in values.
# The app loads ONLY ".env" (never this file). Commit .env.example; do not commit .env.

GROQ_API_KEY=
GITHUB_TOKEN=

# Endee (use a port that does not conflict with FastAPI on 8000)
ENDEE_URL=http://localhost:8001

# Backend URL for Streamlit (uvicorn main:app --port 8000)
API_BASE_URL=http://127.0.0.1:8000

INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local
INNGEST_DEV=1
